{
  "name": "emergentsoft-protocol",
  "version": "1.0.0",
  "description": "EmergentSoft Token Protocol — Burn-to-Earn on Polygon",
  "scripts": {
    "compile":    "hardhat compile",
    "test":       "hardhat test",
    "test:gas":   "REPORT_GAS=true hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network mumbai",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network polygon",
    "verify":     "hardhat verify --network polygon",
    "fork":       "FORK=true hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@chainlink/contracts":    "^1.1.1"
  }
}
