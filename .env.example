# ─── EmergentSoft Protocol — Variables de Entorno ────────────────────────────
# NUNCA commitear este archivo. Agregar .env al .gitignore.

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/TU_API_KEY
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/TU_API_KEY

# ── Deployer ──────────────────────────────────────────────────────────────────
# IMPORTANTE: En producción usar hardware wallet o Gnosis Safe, NUNCA EOA directo
DEPLOYER_PRIVATE_KEY=0x...

# ── API Keys ──────────────────────────────────────────────────────────────────
POLYGONSCAN_API_KEY=TU_POLYGONSCAN_KEY

# ── Backend QAIzero (operator) ────────────────────────────────────────────────
OPERATOR_ADDRESS=0x...
GUARDIAN_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# ── Hedera HCS ────────────────────────────────────────────────────────────────
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=...
HEDERA_TOPIC_ID=0.0.XXXXX   # Crear con: hederaClient.createTopic()
HEDERA_NETWORK=mainnet       # o testnet para desarrollo

# ── Flags ─────────────────────────────────────────────────────────────────────
FORK=false
REPORT_GAS=false
